# OpenSearch Connection
OPENSEARCH_HOST=your-opensearch-host.example.com
OPENSEARCH_PORT=9200
OPENSEARCH_USERNAME=your-username
OPENSEARCH_PASSWORD=your-password
OPENSEARCH_USE_SSL=true
OPENSEARCH_VERIFY_CERTS=true
OPENSEARCH_INDEX=zathras-results

# Demo Mode
# Set to 'true' to use demo data instead of OpenSearch
# Useful for development and demonstrations without OpenSearch access
DEMO_MODE=false

# Demo Scenario (only used when DEMO_MODE=true)
# Options: mixed-health, all-critical, all-ok, cpu-critical
# Defaults to mixed-health if not specified
DEMO_SCENARIO=mixed-health
